{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["sway/workspaces", "sway/mode", "wlr/taskbar"],
    "modules-center": ["sway/window"],
    "modules-right": [
        "tray",
        "custom/separator",
        "niri/language",
        "custom/separator",
        "pulseaudio",
        "custom/separator",
        "backlight",
        "custom/separator",
        "network",
        "custom/separator",
        "custom/vpn",
        "custom/separator",
        "temperature",
        "custom/separator",
        "cpu",
        "custom/separator",
        "memory",
        "custom/separator",
        "battery",
        "custom/separator",
        "clock"
    ],

    "custom/vpn": {
       "interval": 3,
       "format": "{}",
       "exec": "~/.local/bin/get-wireguard-status",
       "max-length": "100",
    },

    "sway/window": {
        "max-length": 50
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 28,
        "spacing": 3,
        "tooltip-format": "{title}",
        "ignore-list": [],
        "on-click": "activate",
        "on-click-middle": "close"
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "disable-click": false,
        "all-outputs": false,
        "format": "{name} ",
    },

    "custom/separator": {
        "format": "|",
        "interval": "once",
        "tooltip": false
    },

    "tray": {
        "spacing": 5,
    },

    "clock": {
        "format": "{:%a %Y-%m-%d %H:%M}",
        "tooltip-format": "<big>{calendar}</big>",
        "calendar": {
          "weeks-pos": "left",
          "format": {
            "today": "<span color='#ff6699'><b><u>{}</u></b></span>",
            "weeks": "<span color='#444444'><b>{:%W}</b></span>",
            "weekdays": "<span color='#cccc66'><b>{}</b></span>",
          }
        },
        "on-click": "gnome-calendar"
    },

    "cpu": {
        "format": "яЛЫ {usage}%"
    },

    "memory": {
        "format": "яГЙ {}%",
        "tooltip-format": "{used:0.1f}/{total:0.1f}GiB used"
    },

    "temperature": {
        "critical-threshold": 75,
        "format": "яЛЙ {temperatureC}┬░C"
    },

    "battery": {
        "bat": "BAT0",
        "states": {
            "good": 95,
            "warning": 20,
            "critical": 10
        },
        "format": "{icon}  {capacity}% - {time}",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"],
        "format-time": "{H}h{M}m",
        "format-charging": "{icon}  яГз {capacity}% - {time}",
        "format-full": "{icon}  яГз full",
        "interval": 60
    },

    "network": {
        "interval": 20,
        "format-wifi": "яЗл {essid}",
        "format-ethernet": "яГБ eth",
        "format-disconnected": "яБ▓",
        "tooltip-format-wifi": "яЗл {essid} ({signalStrength}%) юкб {bandwidthUpBits} юкЪ {bandwidthDownBits}",
        "tooltip-format-ethernet": "яГБ {ifname} юкб {bandwidthUpBits} юкЪ {bandwidthDownBits}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "iwgtk"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "яКФ {icon} {volume}%",
        "format-muted": "ґ░ЦБ",
        "format-icons": {
            "headphone": ["яАе яАж", "яАе яАз", "яАе яАи"],
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },

    "niri/language": {
        "format": "{shortDescription}"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["ґ▒йО", "ґ▒йП", "ґ▒йР", "ґ▒йС", "ґ▒йТ", "ґ▒йУ", "ґ▒йФ", "ґ▒йХ", "ґ▒йЦ", "ґ░Ыи"]
    }
}
